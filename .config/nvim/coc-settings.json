{
    "languageserver": {
        "kotlin": {
            "command": "/opt/homebrew/bin/kotlin-language-server",
            "env": {
                "JAVA_HOME": "/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home"
            },
            "filetypes": ["kotlin"],
            "rootPatterns": [
                "settings.gradle",
                "settings.gradle.kts",
                "build.gradle",
                "build.gradle.kts",
                ".git"
            ],
            "requireRootPattern": true
        }
    }
}
